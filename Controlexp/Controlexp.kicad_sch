	(text "Power Conn handles the connection to a switch but also\ngives the option to directly supply 12v"
		(exclude_from_sim no)
		(at 159.258 60.96 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "472e6447-552c-4f1e-83d9-883b536d90cf")
	)
	(text "Pulling SDO high gives an adddress of 0x77\n for onboard sensor. MS5837 offboard has a\n fixed address of 0x76.\nCSB pulled high sets comm mode to i2c."
		(exclude_from_sim no)
		(at 155.956 145.542 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "7e88113e-9bdc-457b-a820-779f626910c0")
	)
	(text "If this regulator circuit doesn't work for some reason,\nwe have the option to directly supply 3v3 from somehwere else."
		(exclude_from_sim no)
		(at 100.584 178.816 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "a91b8ccd-bf5e-4910-a1cc-2f8c79bbfc6a")
	)
